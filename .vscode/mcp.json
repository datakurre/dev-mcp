{
  "servers": {
    "hal": {
      "type": "stdio",
      "command": "${workspaceFolder}/node_modules/.bin/nodemon",
      "args": [
        "--quiet",
        "--watch",
        "${workspaceFolder}/dist",
        "--ext",
        "js",
        "--exec",
        "node ${workspaceFolder}/dist/index.js"
      ]
    }
  }
}
